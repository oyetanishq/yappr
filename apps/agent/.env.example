# ---------------------------------------------------------
# App
# ---------------------------------------------------------
PORT=8081
APP_ENV=development

# ---------------------------------------------------------
# Redis
# ---------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------
# MongoDB
# ---------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=yappr

# ---------------------------------------------------------
# GitHub App
# ---------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# (for mac) base64 -i ./keys/github-key.pem
GITHUB_APP_PRIVATE_KEY=base64 encoded key
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_NAME=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8080/api/v1/auth/github/callback

# ---------------------------------------------------------
# LLM Provider Configuration
# ---------------------------------------------------------
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_BASE_MODEL=gemini-2.5-flash
LLM_BUG_MODEL=gemini-2.5-pro
