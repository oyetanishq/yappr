# ── App ─────────────────────────────────────────────────────────────────────
PORT=8081
APP_ENV=development

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=yappr

# ── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
