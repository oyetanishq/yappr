# ---------------------------------------------------------
# App
# ---------------------------------------------------------
PORT=8080
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-me-in-production

# ---------------------------------------------------------
# Redis
# ---------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------
# MongoDB
# ---------------------------------------------------------
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=yappr

# ---------------------------------------------------------
# GitHub App
# ---------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# (for mac) base64 -i ./keys/github-key.pem
GITHUB_APP_PRIVATE_KEY=base64 encoded key
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_NAME=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8080/api/v1/auth/github/callback

# ---------------------------------------------------------
# Razorpay (billing)
# ---------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret
# Create a monthly INR plan in the Razorpay dashboard and paste the ID here
RAZORPAY_PLAN_ID=plan_xxxxxxxxxxxx
# Set a webhook secret in the Razorpay dashboard and paste it here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
